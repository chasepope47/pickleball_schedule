rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function callerRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/players/$(request.auth.uid))
        ? get(/databases/$(database)/documents/players/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin()   { return callerRole() == 'admin';   }
    function isManager() { return callerRole() == 'manager'; }

    // Admins and managers can manage users
    function canManage() { return isAdmin() || isManager(); }

    // Player profiles
    match /players/{userId} {
      // Any signed-in user can read player docs (required for leaderboard + reservations)
      allow read: if isSignedIn();

      // Only managers/admins can create profiles (no self-registration)
      allow create: if canManage();

      // Users can update their own profile; managers can update non-admin profiles;
      // admins can update anyone
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (isManager() && resource.data.role != 'admin')
      );

      // Managers can delete non-admin profiles; admins can delete anyone
      allow delete: if isAdmin() || (isManager() && resource.data.role != 'admin');
    }

    // Weekly reservation documents (one per week, keyed YYYY-MM-DD)
    match /reservations/{weekId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && weekId.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    // Match records
    match /matches/{matchId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.uid == request.auth.uid || canManage());
      allow delete: if canManage();
    }

    // Department collection
    match /departments/{deptId} {
      allow read:   if isSignedIn();
      allow create: if canManage();
      allow update: if canManage();
      allow delete: if canManage();
    }

  }
}
