rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reservations collection — one document per week (keyed YYYY-MM-DD)
    match /reservations/{weekId} {

      // Anyone can read the schedule
      allow read: if true;

      // Anyone can write — internal tool, no auth required.
      // Restrict to valid week-key format as a basic safeguard.
      allow write: if weekId.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

  }
}
