rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function callerRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/players/$(request.auth.uid))
        ? get(/databases/$(database)/documents/players/$(request.auth.uid)).data.role
        : null;
    }

    function targetUserRole(targetUid) {
      return exists(/databases/$(database)/documents/players/$(targetUid))
        ? get(/databases/$(database)/documents/players/$(targetUid)).data.role
        : null;
    }

    function isSysAdmin() { return callerRole() == 'system_admin'; }
    function isAdmin()    { return isSysAdmin() || callerRole() == 'admin'; }
    function isManager()  { return callerRole() == 'manager'; }
    function canManage()  { return isAdmin() || isManager(); }

    // Fields a regular user is NOT allowed to change on their own profile
    // NOTE: 'badges' is intentionally excluded — the client badge system needs to write it
    function noPrivilegedFieldChange() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'wins', 'losses', 'rating', 'createdAt', 'email']);
    }

    // Player profiles
    match /players/{userId} {
      allow read: if isSignedIn();

      // Only managers/admins/sysadmins can create profiles (no self-registration)
      allow create: if canManage();

      allow update: if isSignedIn() && (
        // System admin can update any profile
        isSysAdmin() ||
        // Admin can update anyone except system_admin
        (isAdmin() && resource.data.role != 'system_admin') ||
        // Manager can update regular users only
        (isManager() && resource.data.role != 'admin' && resource.data.role != 'system_admin') ||
        // Users can update their own profile but CANNOT change privileged fields
        (request.auth.uid == userId && noPrivilegedFieldChange())
      );

      allow delete: if
        isSysAdmin() ||
        (isAdmin() && resource.data.role != 'system_admin') ||
        (isManager() && resource.data.role != 'admin' && resource.data.role != 'system_admin');
    }

    // Weekly reservation documents (one per week, keyed YYYY-MM-DD)
    match /reservations/{weekId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && weekId.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    // Match records
    match /matches/{matchId} {
      allow read: if isSignedIn();

      // Users can only create match records for themselves; staff can create for anyone
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid || canManage()
      );

      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isAdmin() ||
        (isManager() && targetUserRole(resource.data.uid) != 'admin' && targetUserRole(resource.data.uid) != 'system_admin')
      );

      allow delete: if
        isAdmin() ||
        (isManager() && targetUserRole(resource.data.uid) != 'admin' && targetUserRole(resource.data.uid) != 'system_admin');
    }

    // Department collection
    match /departments/{deptId} {
      allow read:   if isSignedIn();
      allow create: if canManage();
      allow update: if canManage();
      allow delete: if canManage();
    }

    // Rivalry events
    match /rivalries/{rivalryId} {
      allow read:   if isSignedIn();
      allow create: if canManage();
      allow update: if canManage();
      allow delete: if canManage();
    }

    // Tournament records
    match /tournaments/{tournamentId} {
      allow read:   if isSignedIn();
      allow create: if canManage();
      allow update: if canManage();
      allow delete: if canManage();
    }

  }
}
